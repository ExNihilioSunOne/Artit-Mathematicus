import mpmath as mp
import math

# ----------------------------------------------------------------------
# 1. Core 42-Resonance Check
# ----------------------------------------------------------------------

def is_prime(n):
    """Standard primality test for integers up to 10^6."""
    if n < 2:
        return False
    if n % 2 == 0:
        return n == 2
    if n % 3 == 0:
        return n == 3
    i = 5
    while i * i <= n:
        if n % i == 0 or n % (i + 2) == 0:
            return False
        i += 6
    return True

def is_42_resonant(n):
    """Returns True if n is prime and divisible by 42."""
    return is_prime(n) and n % 42 == 0

# ----------------------------------------------------------------------
# 2. Nearest 42-Resonant Prime Finder
# ----------------------------------------------------------------------

def nearest_42_resonant_prime(n, direction=0):
    """
    Finds the nearest prime divisible by 42.
    direction = 0  -> nearest (default)
    direction = -1 -> previous
    direction = 1  -> next
    """
    if n < 42:
        n = 42
    step = 1 if direction >= 0 else -1
    k = 0
    while True:
        base = n + k * step
        # round down to nearest multiple of 42
        candidate = (base // 42) * 42
        if candidate < 2:
            candidate = 42
        if is_42_resonant(candidate):
            return candidate
        k += 1

# ----------------------------------------------------------------------
# 3. Scaling Factor
# ----------------------------------------------------------------------

def scaling_factor(n, prime):
    """Returns the scaling factor n / 42 for a given 42-resonant prime."""
    return mp.mpf(n) / mp.mpf(prime)

# ----------------------------------------------------------------------
