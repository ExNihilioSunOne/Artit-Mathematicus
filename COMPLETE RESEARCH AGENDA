    def solve_puzzle(self, target, op, operand):
        """Solve π-geometry puzzle"""
        if op == '+':
            return f"{target} + {operand} = {target + operand}"
        elif op == '-':
            return f"{target} - {operand} = {target - operand}"
        elif op == '×':
            return f"{target} × {operand} = {target * operand}"
        elif op == '÷':
            return f"{target} ÷ {operand} = {target / operand}"
        elif op == '√':
            return f"√{target} = {sqrt(target)}"

