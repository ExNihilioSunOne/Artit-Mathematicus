def encode_pi_to_dna(pi_digits, length=100):
    """Encode π digits into DNA sequences"""
    
    # Digit-to-base mapping
    mapping = {
        '0': 'ACGT',
        '1': 'ACGA',
        '2': 'ACGC',
        '3': 'ACGG',
        '4': 'AGGT',
        '5': 'AGGA',
        '6': 'AGGC',
        '7': 'AGGG',
        '8': 'ATGT',
        '9': 'ATGA'
    }
    
    # Convert π to DNA
    dna = ""
    for digit in str(pi_digits)[:length]:
        if digit in mapping:
            dna += mapping[digit]
        else:
            dna += 'ACGT'
    
    return dna

