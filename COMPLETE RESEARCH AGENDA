def map_pi_to_constellation(pi_digits, stars=['Orion', 'Ursa Major', 'Cassiopeia']):
    """Map π digits to stellar coordinates"""
    
    constellations = {}
    for i, digit in enumerate(str(pi_digits)[:30]):
        if digit.isdigit():
            # Use digit to determine star position
            star_index = int(digit) % len(stars)
            position = i * 10  # Degrees
            const_name = stars[star_index]
            
            if const_name not in constellations:
                constellations[const_name] = []
            constellations[const_name].append(position)
    
    return constellations

