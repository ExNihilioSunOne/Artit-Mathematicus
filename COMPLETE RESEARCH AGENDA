def zero_knowledge_pi_proof(secret_pi_digits):
    """Prove knowledge of π without revealing digits"""
    
    # Commit to digits
    commit = hashlib.sha256(secret_pi_digits.encode()).hexdigest()
    
    # Challenge-response
    challenge = random.randint(1, 1000)
    response = hashlib.sha256((secret_pi_digits + str(challenge)).encode()).hexdigest()
    
    return {
        'commit': commit,
        'response': response,
        'challenge': challenge
    }

